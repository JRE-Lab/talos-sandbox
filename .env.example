# TALOS Sandbox — environment configuration (example)
# =====================================================================
# Copy this file to `.env` and edit as needed:   cp .env.example .env
#
# The real `.env` is gitignored and MUST NEVER be committed — it holds the
# OpenAI key. With NO secrets set, the stack still serves the full replay
# sandbox; live mode simply stays disabled.
# =====================================================================

# --- Fleet simulation ------------------------------------------------
# Fleet backend selector. "sim" is the only backend shipped in the sandbox
# ("winrm" is a documented placeholder that never talks to real hosts).
SANDBOX_BACKEND=sim

# Soak/time compression factor. A 120s soak completes in ~120/SIM_SPEED s.
SIM_SPEED=12

# Sim-seconds the bad build (2.1.5) holds baseline before it degrades.
REGRESSION_DELAY_S=8

# --- Live mode (real OpenAI agents vs. the simulated fleet) -----------
# Master switch. Live mode runs ONLY when this is true AND OPENAI_API_KEY is
# set. Leave false for a pure-replay deployment (the safe default).
LIVE_MODE_ENABLED=false

# OpenAI API key for live agents. Leave BLANK to keep live mode disabled.
# Never logged, never sent to the client. Setting this is what arms live mode
# (together with LIVE_MODE_ENABLED=true).
OPENAI_API_KEY=

# Model used by the live reference agents.
OPENAI_MODEL=gpt-4o-mini

# Hard USD spend cap. When cumulative estimated spend reaches this, live runs
# are refused and the judge is handed a replay instead (fail-safe).
LIVE_BUDGET_CAP=25.0

# Global accepted live runs per hour, across all callers.
LIVE_RUNS_PER_HOUR=20

# Per-session live runs (a single browser session/cookie).
LIVE_RUNS_PER_SESSION=3

# Max characters accepted in a live directive (input bound).
LIVE_MAX_DIRECTIVE_CHARS=500

# Spend estimation for the budget kill-switch (local accounting only — these do
# NOT bill anything; they drive when live mode falls back to replay). Estimated
# cost per 1K prompt/completion tokens, and a flat fallback when a run reports no
# token usage. Defaults are conservative placeholders for a gpt-4o-mini-class
# model; raise them if you want the cap to trip sooner.
LIVE_PRICE_PER_1K_PROMPT=0.0006
LIVE_PRICE_PER_1K_COMPLETION=0.0024
LIVE_FLAT_RUN_ESTIMATE=0.05

# --- Front-end / deployment ------------------------------------------
# Demo video link injected into the "Watch it run on real VMs" header link.
# Replace with the real recording before shipping.
VIDEO_URL=REPLACE_WITH_VIDEO_URL

# Subdomain Caddy obtains a TLS cert for and reverse-proxies.
TALOS_DOMAIN=talos.example.com
